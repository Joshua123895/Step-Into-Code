        track:
        - log.txt
      id: 70
      max: 3/1
      obj: Open `"log.txt"` in append mode and write `"done"`.
      expl: '`"a"` appends content to the end of a file instead of overwriting it.'
      sol: "with open(\"log.txt\", \"a\") as f:\n    f.write(\"done\")"
      start: ''
    - name: Read Lines
