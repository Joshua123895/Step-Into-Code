      obj: 'Read three integers: `a`, `b`, `c`. Compute and print: (1) `a + b * c`, (2) `(a + b) * c`, (3) `a ** b`, (4) `b
        % a`, (5) `a // c`, (6) whether `a > b and b > c`, (7) whether `a == b or b == c`, (8) whether `not (a > c)`. Use
        `**`, `%`, `//`, `and`, `or`, and `not`.'
      sol: 'a = int(input())

        b = int(input())

        c = int(input())

        print(a + b * c)

        print((a + b) * c)

        print(a ** b)

        print(b % a)

        print(a // c)

        print(a > b and b > c)

        print(a == b or b == c)

        print(not (a > c))'
      start: ''
    - name: Decision Engine
      example:
        input:
        - '95'
        - '60'
        - 'yes'
        output: 'Excellent

          '
      tests:
      - in:
        - '95'
        - '60'
        - 'yes'
        exp: 'Excellent

