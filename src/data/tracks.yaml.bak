    - name: Conditionals
      icon: if
      levels:
        - name: Simple If
          obj: 'Read an integer into `x`. If `x > 0`, print `"Positive"`.'
          hint: |-
            Try:`x = int(input())
            if x > 0:
                print("Positive")`
          expl: 'The `if` statement runs code only when its condition is true.'
          start: |
            x = int(input())
          sol: |-
            if x > 0:
                print("Positive")
          tests:
            - in: '5'
              exp: |
                Positive
          max: 3/1
        - name: Checking Equality
          obj: 'Read a number into `x`. If `x == 10`, print `"Ten"`.'
          hint: 'Use `==` inside an if statement.'
          expl: '`==` checks whether two values are equal.'
          start: |
            x = int(input())
          sol: |-
            if x == 10:
                print("Ten")
          tests:
            - in: '10'
              exp: |
                Ten
            - in: '7'
              exp: ''
          max: 3/1
        - name: If-Else
          obj: 'Read an age into `age`. If `age >= 18`, print `"Adult"`, otherwise print `"Minor"`.'
          hint: 'Use `if` and `else`.'
          expl: '`else` provides an alternative path when the condition is false.'
          start: |
            age = int(input())
          sol: |-
            if age >= 18:
                print("Adult")
            else:
                print("Minor")
          tests:
            - in: '20'
              exp: |
                Adult
            - in: '15'
              exp: |
                Minor
          max: 5/1
        - name: Multiple Conditions
          obj: 'Read a number into `x`. If `x > 0 and x < 10`, print `"Small Positive"`.'
          hint: 'Combine comparisons using `and`.'
          expl: Conditions can be combined using logical operators.
          start: |
            x = int(input())
          sol: |-
            if x > 0 and x < 10:
                print("Small Positive")
          tests:
            - in: '5'
              exp: |
                Small Positive
            - in: '15'
              exp: ''
          max: 3/1
        - name: Elif Chain
          obj: 'Read a score into `score`. Print `"A"` if it is at least 90, `"B"` if it is at least 80, otherwise print `"C"`.'
          hint: 'Use `if`, `elif`, and `else`.'
          expl: '`elif` allows you to check several conditions in sequence.'
          start: |
            score = int(input())
          sol: |-
            if score >= 90:
                print("A")
            elif score >= 80:
                print("B")
            else:
                print("C")
          tests:
            - in: '95'
              exp: |
                A
            - in: '85'
              exp: |
                B
