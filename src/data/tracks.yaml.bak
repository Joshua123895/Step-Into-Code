        - name: Redirect Output
          obj: 'Import `redirect_stdout` from `contextlib` and redirect print output to a `StringIO` buffer. Print the captured text.'
          hint: '`from io import StringIO` and `with redirect_stdout(buffer):`.'
          expl: '`redirect_stdout` temporarily redirects all `print()` output to a stream like `StringIO`. Useful for capturing logs or test output.'
          sol: |-
            from contextlib import redirect_stdout
            from io import StringIO
            buf = StringIO()
            with redirect_stdout(buf):
                print("Captured!")
            print(buf.getvalue().strip())
          tests:
            - |
              Captured!
          max: 7/1
        - name: Timer Context Manager
          obj: 'Use `@contextmanager` to create a `timer` that prints elapsed time in seconds on exit. Import `time`.'
          hint: 'Record `start = time.time()` before `yield`, then subtract after.'
          expl: 'Context managers are great for measuring execution time — setup records the start, teardown computes and reports the delta.'
          sol: |-
            from contextlib import contextmanager
            import time
            @contextmanager
            def timer():
                start = time.time()
                yield
                elapsed = time.time() - start
                print(f"{elapsed:.3f}s")
            with timer():
                total = sum(range(100000))
            print("Done")
          tests: []
          max: 9/1
         - name: ExitStack
           obj: 'Use `ExitStack` from `contextlib` to manage two `redirect_stdout` contexts. Read a name, capture two print outputs, and print the captured text.'
           hint: '`from contextlib import ExitStack, redirect_stdout` — use `stack.enter_context(redirect_stdout(buf))` to redirect.'
            expl: "`ExitStack` lets you manage multiple context managers dynamically. All entered contexts are cleaned up when you exit the stack, even if you don't know the number upfront."
           sol: |-
             from contextlib import ExitStack, redirect_stdout
             from io import StringIO
             name = input()
             buf1 = StringIO()
             buf2 = StringIO()
             with ExitStack() as stack:
                 stack.enter_context(redirect_stdout(buf1))
                 print(f"Hello, {name}")
                 stack.enter_context(redirect_stdout(buf2))
                 print(f"Welcome, {name}")
             print(buf1.getvalue().strip())
             print(buf2.getvalue().strip())
           tests:
             - in: Alice
               exp: |
                 Hello, Alice
                 Welcome, Alice
             - in: Bob
               exp: |
                 Hello, Bob
                 Welcome, Bob
           max: 14/1
         - name: Context Manager Puzzle
          example:
            in: []
            out: |
              Enter
              Value: 42
              Exit
          sol: |-
            class Provider:
                def __enter__(self):
                    print("Enter")
                    return 42
                def __exit__(self, *args):
                    print("Exit")
            with Provider() as val:
                print(f"Value: {val}")
          tests:
            - exp: |
                Enter
                Value: 42
                Exit
          max: 7/1
