    - name: File Handling
      icon: file
      levels:
        - name: Write a File
          obj: 'Open `"test.txt"` in write mode using `with open(...) as f:` and write `"Hello"`.'
          hint: |-
            Try:`with open("test.txt", "w") as f:
                f.write("Hello")`
          expl: 'The `with` statement automatically closes files. `"w"` mode creates or overwrites a file.'
