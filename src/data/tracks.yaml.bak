          obj: 'A guard allows travelers into the castle. Read an age and whether they have a permit (yes/no). Print `"Welcome"` if age ≥ 18 OR permit is `"yes"`, otherwise print `"Come Back Later"`.'
          sol: |-
            age = int(input())
            permit = input()
            if age >= 18 or permit == "yes":
                print("Welcome")
            else:
                print("Come Back Later")
